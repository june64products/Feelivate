# Copy this file to `.env` and fill in real values.

# Auth — JWT signing secret. MUST be a long random string and the SAME value
# everywhere (local + production). Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# WARNING: changing this value logs out every existing user (invalidates tokens).
JWT_SECRET_KEY="set-a-long-random-secret-here"

# LLM API Keys (choose one)
# Google Gemini API key
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL="gemini-1.5-flash"

# OR OpenAI API key (do NOT commit real keys)
# OPENAI_API_KEY="your-openai-api-key-here"
# OPENAI_LLM_MODEL="gpt-4o-mini"

# Redis connection URL
# Examples:
#   redis://localhost:6379/0
#   rediss://:password@your-host:6380/0
REDIS_URL="redis://localhost:6379/0"